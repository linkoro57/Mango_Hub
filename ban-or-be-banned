    if not scriptAlive then
        return
    end

    character = newChar
    newChar:WaitForChild("HumanoidRootPart")
    task.wait(0.4)

    if state.moneyMagnet then
        startLoop()
    end
    if state.autoEquipSelectedTool then
        equipPreferredTool()
    end
end)

