task.spawn(function()
    while scriptAlive do
        updateStatsParagraph()
        updateInventoryParagraph()
        updateAutomationParagraph()

        if state.autoClaimDaily then
            local nextRewardTime = player:FindFirstChild("NextRewardTime")
            if nextRewardTime and nextRewardTime.Value <= os.time() then
                pcall(function()
                    ReplicatedStorage.ClaimDailyReward:FireServer()
                end)
            end
        end

        if state.autoClaimFreePack then
            local claimed = player:FindFirstChild("FreePackClaimed")
            local timer = player:FindFirstChild("FreePackTime")
            if claimed and not claimed.Value and timer and timer.Value <= 0 then
                pcall(function()
                    ReplicatedStorage.ClaimFreePack:FireServer()
                end)
            end
        end

        if state.autoMoneyButtons then
            for i = 1, 7 do
                if not scriptAlive or not state.autoMoneyButtons then
                    break
                end
                local part = getButtonPart("ButtonsMoney", "Button" .. i)
                if part then
                    touchPart(part)
                    task.wait(0.12)
                end
            end
        end

        if state.autoEquipSelectedTool then
            equipPreferredTool()
        end

        task.wait(1)
    end
end)

