local function findMatchingTool(name)
    if name == "None" then
        return nil
    end

    local aliases = toolAliases[name] or { name }
    local lookup = {}
    for _, alias in ipairs(aliases) do
        lookup[normalizeName(alias)] = true
    end

    local containers = { player.Backpack, getCharacter() }
    for _, container in ipairs(containers) do
        if container then
            for _, child in ipairs(container:GetChildren()) do
                if child:IsA("Tool") and lookup[normalizeName(child.Name)] then
                    return child
                end
            end
        end
    end

    return nil
end

local function equipPreferredTool()
    local humanoid = getHumanoid()
    if not humanoid or state.preferredTool == "None" then
        return false
    end

    local tool = findMatchingTool(state.preferredTool)
    if not tool then
        return false
    end

    pcall(function()
        humanoid:EquipTool(tool)
    end)
    return true
end

local function claimOwnedTool(toolName)
    local ownedValue = player:FindFirstChild("OwnedTools") and player.OwnedTools:FindFirstChild(toolName)
    if not ownedValue or ownedValue.Value ~= true then
        return false
    end

    local giverName = ({
        GravityCoil = "Gravity Coil Giver",
        SpeedCoil = "Speed Coil Giver",
        MagicCarpet = "Rainbow Magic Carpet giver",
    })[toolName]

    if not giverName then
        return false
    end

    local toolsFolder = Workspace:FindFirstChild("Tools")
    local giver = toolsFolder and toolsFolder:FindFirstChild(giverName)
    local giverPart = giver and giver:FindFirstChildWhichIsA("BasePart", true)
    if not giverPart then
        return false
    end

    return touchPart(giverPart)
end

