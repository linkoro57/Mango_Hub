local function triggerSelectedDuration(folderName, buttonMap, selectedDuration)
    local part = getButtonPart(folderName, buttonMap[selectedDuration])
    if not part then
        return false
    end
    return touchPart(part)
end

local function triggerSelectedPlayerPrompt()
    local target = Players:FindFirstChild(state.selectedPlayer or "")
    local targetCharacter = target and target.Character
    local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
    local prompt = targetRoot and targetRoot:FindFirstChild("BanPrompt")
    if not prompt then
        return false
    end

    if type(fireproximityprompt) == "function" then
        pcall(function()
            fireproximityprompt(prompt)
        end)
        return true
    end

    return false
end

