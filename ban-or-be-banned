local function refreshMoneyParts()
    moneyParts = getMoneyParts()
    for _, part in ipairs(moneyParts) do
        preparePart(part)
    end
end

local function startLoop()
    if loopConn then
        loopConn:Disconnect()
        loopConn = nil
    end

    refreshMoneyParts()
    loopConn = RunService.Heartbeat:Connect(function(dt)
        if not state.moneyMagnet then
            return
        end

        local torso = getTorso()
        if not torso then
            return
        end

        local anyMissing = false
        for _, part in ipairs(moneyParts) do
            if not part or not part.Parent then
                anyMissing = true
                break
            end
        end

        if anyMissing then
            refreshMoneyParts()
        end

        hue = (hue + dt * 0.08) % 1
        spinAngle = (spinAngle + dt * state.spinSpeed) % (2 * math.pi)

        for _, part in ipairs(moneyParts) do
            pcall(function()
                local distance = (part.Position - torso.Position).Magnitude
                if distance <= state.collectRange or state.collectRange >= 30 then
                    part.Color = Color3.fromHSV(hue, 1, 1)
                    part.CFrame = CFrame.new(torso.Position)
                        * CFrame.Angles(spinAngle, spinAngle * 1.3, spinAngle * 0.7)
                end
            end)
        end
    end)
end

local function stopLoop()
    if loopConn then
        loopConn:Disconnect()
        loopConn = nil
    end
end

local function getButtonPart(folderName, buttonName)
    local folder = Workspace:FindFirstChild(folderName)
    local model = folder and folder:FindFirstChild(buttonName)
