        lbl.TextSize = isMobile and 14 or 13
        lbl.TextColor3 = TXT
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text = label
        lbl.Parent = row

        local sub = Instance.new("TextLabel")
        sub.BackgroundTransparency = 1
        sub.Size = UDim2.new(1, isMobile and -74 or -58, 0, 12)
        sub.Position = UDim2.new(0, 0, 0, isMobile and 28 or 23)
        sub.Font = Enum.Font.Gotham
        sub.TextSize = smallText
        sub.TextColor3 = SUB
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.Text = description
        sub.Parent = row

        local sw = Instance.new("TextButton")
        sw.Text = ""
        sw.AutoButtonColor = false
        local switchWidth = isMobile and 48 or 42
        local switchHeight = isMobile and 26 or 22
        local knobSize = isMobile and 22 or 18
        sw.Size = UDim2.new(0, switchWidth, 0, switchHeight)
        sw.Position = UDim2.new(1, -switchWidth, 0.5, -math.floor(switchHeight / 2))
        sw.BackgroundColor3 = OFFCOL
        sw.BorderSizePixel = 0
        sw.Parent = row
        corner(sw, math.floor(switchHeight / 2))

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, knobSize, 0, knobSize)
        knob.Position = UDim2.new(0, 2, 0.5, -math.floor(knobSize / 2))
        knob.BackgroundColor3 = Color3.fromRGB(236, 236, 236)
        knob.BorderSizePixel = 0
        knob.Parent = sw
        corner(knob, math.floor(knobSize / 2))

        local function render()
            local on = state[key]
            sw.BackgroundColor3 = on and ACCENT or OFFCOL
            knob.Position = on and UDim2.new(1, -(knobSize + 2), 0.5, -math.floor(knobSize / 2)) or UDim2.new(0, 2, 0.5, -math.floor(knobSize / 2))
        end

        sw.MouseButton1Click:Connect(function()
            state[key] = not state[key]
            if key == "AutoFruit" and state[key] then
                gatherFruit()
            end
            render()
        end)

        render()
    end

    section("AUTO FARM")
    toggleRow("Auto Buy Tiles", "Buys affordable purchase tiles", "AutoBuy")
    toggleRow("Auto Upgrade Earners", "Bulk upgrades cash machines", "AutoUpgradeEarners")
    toggleRow("Auto Upgrade Powers", "Spends investors on powers", "AutoUpgradePowers")
    toggleRow("Auto Collect Fruit", "Harvests lemons automatically", "AutoFruit")
    toggleRow("Auto Wake Earners", "Triggers manual earners", "AutoWake")
    toggleRow("Auto Collect Cash Drops", "Claims drops instantly", "AutoCashDrop")
    toggleRow("Auto Phone Deals", "Accepts phone deals", "AutoPhone")

    section("PROGRESSION")
    toggleRow("Auto Rebirth", "Rebirths automatically", "AutoRebirth")
    toggleRow("Auto Evolve", "Evolves at 100%", "AutoEvolve")
    toggleRow("Auto Ascend", "Ascends at 100%", "AutoAscend")

    section("UTILITY")
    toggleRow("Anti-AFK", "Prevents idle disconnect", "AntiAFK")
    toggleRow("Enable Walk Speed", "Applies custom speed", "SpeedOn")

    local speedRow = Instance.new("Frame")
