    speedRow.BackgroundColor3 = BG2
    speedRow.BorderSizePixel = 0
    speedRow.LayoutOrder = nextOrder()
    speedRow.Parent = body
    corner(speedRow, 10)
    pad(speedRow, 0, 0, 11, 11)

    local speedLabel = Instance.new("TextLabel")
    speedLabel.BackgroundTransparency = 1
    speedLabel.Size = UDim2.new(1, isMobile and -72 or -58, 0, 15)
    speedLabel.Position = UDim2.new(0, 0, 0, isMobile and 10 or 7)
    speedLabel.Font = Enum.Font.GothamBold
    speedLabel.TextSize = isMobile and 14 or 13
    speedLabel.TextColor3 = TXT
    speedLabel.TextXAlignment = Enum.TextXAlignment.Left
    speedLabel.Text = "Walk Speed"
    speedLabel.Parent = speedRow

    local speedValue = Instance.new("TextLabel")
    speedValue.BackgroundTransparency = 1
    speedValue.Size = UDim2.new(0, 60, 0, 15)
    speedValue.Position = UDim2.new(1, -70, 0, isMobile and 10 or 7)
    speedValue.Font = Enum.Font.Gotham
    speedValue.TextSize = isMobile and 13 or 12
    speedValue.TextColor3 = SUB
    speedValue.TextXAlignment = Enum.TextXAlignment.Right
    speedValue.Text = tostring(state.SpeedVal)
    speedValue.Parent = speedRow

    local track = Instance.new("Frame")
    local sliderTrackHeight = isMobile and 8 or 6
    local sliderKnobSize = isMobile and 18 or 14
    track.Size = UDim2.new(1, 0, 0, sliderTrackHeight)
    track.Position = UDim2.new(0, 0, 1, -16)
    track.BackgroundColor3 = BG3
    track.BorderSizePixel = 0
    track.Parent = speedRow
    corner(track, math.floor(sliderTrackHeight / 2))

    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = ACCENT
    fill.BorderSizePixel = 0
    fill.Parent = track
    corner(fill, math.floor(sliderTrackHeight / 2))

    local speedKnob = Instance.new("Frame")
    speedKnob.Size = UDim2.new(0, sliderKnobSize, 0, sliderKnobSize)
    speedKnob.BackgroundColor3 = TXT
    speedKnob.BorderSizePixel = 0
    speedKnob.ZIndex = 2
    speedKnob.Parent = track
    corner(speedKnob, math.floor(sliderKnobSize / 2))

    local function setSpeedAlpha(alpha)
        alpha = math.clamp(alpha, 0, 1)
        local value = math.floor(16 + (150 - 16) * alpha + 0.5)
        state.SpeedVal = value
        speedValue.Text = tostring(value)
        fill.Size = UDim2.new(alpha, 0, 1, 0)
        speedKnob.Position = UDim2.new(alpha, -math.floor(sliderKnobSize / 2), 0.5, -math.floor(sliderKnobSize / 2))
    end

    setSpeedAlpha((state.SpeedVal - 16) / (150 - 16))

    local draggingSlider = false
    local function updateSlider(x)
        setSpeedAlpha((x - track.AbsolutePosition.X) / track.AbsoluteSize.X)
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = true
            updateSlider(input.Position.X)
        end
    end)

    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end)

    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)

    updateUi = function()
        if not gui.Parent then
            return
        end
        vCash.Text = status.cash
        vInv.Text = status.investors
        vReb.Text = status.rebirths
        vEvo.Text = status.evolve
        vActions.Text = status.actions
    end

    local function clampWindowPosition()
        if isMobile then
            main.Position = UDim2.new(0.5, 0, 0.5, 0)
            return
        end

        local currentViewport = getViewportSize()
        local maxX = math.max(8, currentViewport.X - main.AbsoluteSize.X - 8)
        local maxY = math.max(8, currentViewport.Y - main.AbsoluteSize.Y - 8)
        local offsetX = math.clamp(main.Position.X.Offset, 8, maxX)
        local offsetY = math.clamp(main.Position.Y.Offset, 8, maxY)
        main.Position = UDim2.new(0, math.floor(offsetX), 0, math.floor(offsetY))
    end

    local dragging, dragStart, startPos
    if not isMobile then
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = main.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)

        game:GetService("UserInputService").InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                clampWindowPosition()
            end
        end)
    end

    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        main.Size = minimized and UDim2.new(0, frameWidth, 0, barHeight) or UDim2.new(0, frameWidth, 0, frameHeight)
        clampWindowPosition()
    end)

    closeBtn.MouseButton1Click:Connect(function()
        scriptAlive = false
        for key, value in pairs(state) do
            if type(value) == "boolean" then
                state[key] = false
            end
        end
        gui:Destroy()
    end)

    local camera = workspace.CurrentCamera
    if camera then
        camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
            clampWindowPosition()
        end)
    end

    clampWindowPosition()
end

